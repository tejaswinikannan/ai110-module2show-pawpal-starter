classDiagram
    class Owner {
        +String name
        +int numberOfPets
        +List~Pet~ pets
        +createOwner() Owner
    }

    class Pet {
        +String petType
        +String name
        +List~Task~ tasks
        +addPet() Pet
        +feed() void
        +scheduleWalk() void
    }

    class Task {
        +String taskTitle
        +int taskId
        +viewTasks() List
        +addTask() void
    }

    class Scheduler {
        +int taskId
        +String taskTitle
        +String taskTime
        +prioritizeTasks() List
        +viewDailyRoutines(Owner) List
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Task "1..*" --> "1" Scheduler : managed by
